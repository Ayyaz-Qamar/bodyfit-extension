{
  "manifest_version": 3,
  "name": "BodyFit - AI Shirt Size Recommender",
  "version": "0.1.0",
  "description": "AI-powered shirt size recommendation using pose detection",
  
  "permissions": ["activeTab", "storage"],
  
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "BodyFit Size Recommender"
  }
}